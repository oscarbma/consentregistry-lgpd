# Sobrescritas opcionais para a rede Besu local.
# Por padrão, hardhat.config.ts lê o RPC em http://localhost:8545 e as chaves
# dos validadores em ../network/nodes/node{1,2,3}/data/key (em runtime, fs).
# Defina estas variáveis apenas se quiser sobrescrever esse comportamento.

# BESU_RPC_URL=http://localhost:8545
# Chaves privadas separadas por vírgula (com ou sem prefixo 0x).
# BESU_PRIVATE_KEYS=0x...,0x...,0x...
